        <tr>
            <td class="label">জন্মস্থান</td>
            <td class="value">: &nbsp; হবিগঞ্জ</td>
        </tr>
    </table>

    <!-- ব্যক্তিগত তথ্য -->
    <div class="section-title">ব্যক্তিগত তথ্য</div>
    <table class="info-table">
        <tr>
            <td class="label">নাম (বাংলা)</td>
            <td class="value">: &nbsp; আঃ রেজাক</td>
        </tr>
        <tr>
            <td class="label">নাম (ইংরেজি)</td>
            <td class="value">: &nbsp; ABDUR RAZZAK</td>
        </tr>
        <tr>
            <td class="label">জন্ম তারিখ</td>
            <td class="value">: &nbsp; 1966-01-01</td>
        </tr>
        <tr>
            <td class="label">পিতার নাম</td>
            <td class="value">: &nbsp; আঃ মনাফ</td>
        </tr>
        <tr>
            <td class="label">মাতার নাম</td>
            <td class="value">: &nbsp; লাল বানু</td>
        </tr>
    </table>

    <!-- অন্যান্য তথ্য -->
    <div class="section-title">অন্যান্য তথ্য</div>
    <table class="info-table">
        <tr>
            <td class="label">লিঙ্গ</td>
            <td class="value">: &nbsp; male</td>
        </tr>
        <tr>
            <td class="label">জন্মবার</td>
            <td class="value">: &nbsp; শনিবার</td>
        </tr>
        <tr>
            <td class="label">রক্তের গ্রুপ</td>
            <td class="value">: &nbsp; -</td>
        </tr>
        <tr>
