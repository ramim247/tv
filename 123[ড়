<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>National Identity Registration Wing (NIDW)</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif, Arial, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 850px;
            margin: 0 auto;
            background: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-top: 5px solid #006a4e;
        }
        .header {
            text-align: center;
            border-bottom: 2px solid #eeecf2;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        .header h1 {
            color: #006a4e;
            margin: 5px 0;
            font-size: 24px;
        }
        .header h2 {
            color: #f47920;
            margin: 5px 0;
            font-size: 18px;
        }
        .profile-section {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            background: #f9f9f9;
            padding: 15px;
            border-radius: 6px;
            border: 1px solid #e2e8f0;
        }
        .profile-images {
            display: flex;
            gap: 15px;
        }
        .profile-images img {
            width: 110px;
            height: 130px;
            object-fit: cover;
            border: 2px solid #cbd5e1;
            border-radius: 4px;
        }
        .qr-code {
            width: 100px;
            height: 100px;
            border: 1px solid #cbd5e1;
            padding: 5px;
            background: #fff;
        }
        .section-title {
            background-color: #006a4e;
            color: white;
            padding: 8px 12px;
            font-weight: bold;
            margin-top: 20px;
            margin-bottom: 10px;
            border-radius: 4px;
            font-size: 16px;
        }
        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }
        .info-table td {
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
            font-size: 15px;
        }
        .info-table td.label {
            width: 30%;
            font-weight: bold;
            color: #4a5568;
        }
        .info-table td.value {
            width: 70%;
            color: #1a202c;
        }
        .footer-note {
            margin-top: 30px;
            font-size: 12px;
            color: #718096;
            text-align: center;
            border-top: 1px dashed #cbd5e1;
            padding-top: 15px;
            line-height: 1.6;
        }
        @media print {
            body { background: #fff; padding: 0; }
            .container { box-shadow: none; border: none; padding: 0; }
            .section-title { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>

<div class="container">
    
    <!-- Header Section -->
    <div class="header">
        <h1>Bangladesh Election Commission</h1>
        <h2>National Identity Registration Wing (NIDW)</h2>
        <p style="margin: 5px 0; font-weight: bold; color: #555;">Software Generated Report</p>
    </div>

    <!-- Images & Top Info -->
    <div class="profile-section">
        <div class="profile-images">
            <!-- আপনার ছবির লিংক এখানে বসাবেন -->
            <img src="photo.jpg" alt="Photo">
            <!-- আপনার কিউআর কোডের লিংক এখানে বসাবেন -->
            <img src="qr.jpg" alt="QR Code" class="qr-code">
        </div>
        <div style="text-align: right;">
            <p style="margin: 0; font-size: 14px; color: #718096;">Search Category: <strong>NID/Voter No</strong></p>
            <p style="margin: 5px 0 0 0; font-size: 18px; color: #006a4e; font-weight: bold;">Status: Verified</p>
